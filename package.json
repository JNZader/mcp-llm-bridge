{
  "name": "mcp-llm-bridge",
  "version": "0.2.0",
  "description": "MCP server that routes LLM calls through CLI subscriptions (Claude, Gemini, Codex, Copilot)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-llm-bridge": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/**/*.test.ts"
  },
  "keywords": ["mcp", "llm", "claude", "gemini", "codex", "copilot", "bridge", "gateway"],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
