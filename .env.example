# LLM Gateway Configuration
# Copy this file to .env and adjust values as needed.

# Master encryption key for the credential vault.
# Must be a 64-character hex string (32 bytes).
# If not set, a key is auto-generated and stored at ~/.llm-gateway/master.key
# LLM_GATEWAY_MASTER_KEY=

# Path to the SQLite credential vault database.
# Default: ~/.llm-gateway/vault.db
# LLM_GATEWAY_DB_PATH=~/.llm-gateway/vault.db

# HTTP server port for the gateway API.
# Default: 3456
# LLM_GATEWAY_PORT=3456

# Bearer token for HTTP API authentication.
# Must be at least 32 characters. If not set, auth is disabled (local dev).
# In production (NODE_ENV=production), this is required.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# LLM_GATEWAY_AUTH_TOKEN=

# CORS allowed origins (comma-separated list).
# If not set, defaults to allowing only GitHub Pages dashboard.
# Use '*' to allow all origins (not recommended for production).
# Example: 'https://example.com,https://app.example.com'
# LLM_GATEWAY_CORS_ORIGINS=

# Environment indicator for production mode.
# If set to 'production', auth is required and startup fails without LLM_GATEWAY_AUTH_TOKEN.
# NODE_ENV=production
